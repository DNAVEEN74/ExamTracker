model AdmitCard {
  id               String          @id @default(uuid())
  user_id          String
  exam_id          String
  exam_post_id     String?
  status           AdmitCardStatus @default(NOT_RELEASED)
  download_url     String?
  roll_number      String?
  exam_center      String?
  exam_center_code String?
  reporting_time   String?
  exam_shift       String?
  notes            String?
  released_at      DateTime?
  downloaded_at    DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  exam      Exam      @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  exam_post ExamPost? @relation(fields: [exam_post_id], references: [id], onDelete: SetNull)

  @@unique([user_id, exam_id])
  @@index([user_id])
  @@index([exam_id])
  @@index([status])
  @@map("admit_cards")
}
