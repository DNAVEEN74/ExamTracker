generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum OnboardingMode {
  FOCUSED
  DISCOVERY
  VACANCY_AWARE
  COMPREHENSIVE
}

enum Category {
  GENERAL
  OBC_NCL
  OBC_CL
  SC
  ST
  EWS
}

enum QualificationLevel {
  CLASS_10
  CLASS_12
  ITI
  DIPLOMA
  GRADUATION
  POST_GRADUATION
  DOCTORATE
  PROFESSIONAL_CA
  PROFESSIONAL_CS
  PROFESSIONAL_ICWA
  PROFESSIONAL_LLB
  PROFESSIONAL_MBBS
  PROFESSIONAL_BED
}

enum Nationality {
  INDIAN
  NEPAL_BHUTAN
  PIO
  OCI
}

enum Gender {
  MALE
  FEMALE
  THIRD_GENDER
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  UNMARRIED
  MARRIED
  DIVORCED
  WIDOWED
}

enum ExamCategory {
  SSC
  RAILWAY
  BANKING
  UPSC_CIVIL
  STATE_PSC
  DEFENCE
  POLICE
  TEACHING
  PSU
  OTHER
}

enum ExamLevel {
  CENTRAL
  STATE
  PSU
  DEFENCE
  BANKING
}

enum TrackedStatus {
  TRACKING
  APPLIED
  APPEARED
  RESULT_AWAITED
  SELECTED
  NOT_SELECTED
  WITHDRAWN
}

enum DataSource {
  MANUAL
  SCRAPER
  RSS
  API
}

// ─── Models (Tables) ────────────────────────────────────────────────────────

model User {
  id                   String                   @id
  email                String?                  @unique
  display_name         String
  email_verified       Boolean                  @default(false)
  auth_provider        String                   @default("email")
  google_id            String?                  @unique
  onboarding_mode      OnboardingMode?
  onboarding_completed Boolean                  @default(false)
  onboarding_step      Int                      @default(0)
  created_at           DateTime                 @default(now())
  updated_at           DateTime                 @updatedAt
  last_active_at       DateTime                 @default(now())
  is_deleted           Boolean                  @default(false)
  deleted_at           DateTime?

  profile              UserProfile?
  preferences          NotificationPreferences?
  tracked_exams        TrackedExam[]
  otps                 Otp[]

  @@map("users")
}

model Otp {
  id         String   @id @default(uuid())
  email      String
  code       String
  expires_at DateTime
  created_at DateTime @default(now())
  used       Boolean  @default(false)

  user       User?    @relation(fields: [email], references: [email])

  @@index([email, code])
  @@map("otps")
}

model UserProfile {
  id                        String              @id @default(uuid())
  user_id                   String              @unique
  date_of_birth             DateTime?           @db.Date
  category                  Category?
  highest_qualification     QualificationLevel?
  qualification_stream      String?
  marks_percentage          Float?
  is_final_year             Boolean             @default(false)
  expected_completion       DateTime?           @db.Date
  additional_qualifications String[]            @default([])
  nationality               Nationality?
  domicile_state            String?
  current_state             String?
  exam_states               String[]            @default([])
  languages_known           String[]            @default([])
  gender                    Gender?
  height_cm                 Float?
  has_vision_correction     Boolean?
  is_pwd                    Boolean             @default(false)
  pwd_type                  String?
  pwd_percentage            Float?
  is_ex_serviceman          Boolean             @default(false)
  ex_service_type           String?
  ex_service_years          Float?
  marital_status            MaritalStatus?
  is_government_employee    Boolean             @default(false)
  has_sports_achievement    Boolean             @default(false)
  sports_level              String?
  exam_categories           ExamCategory[]      @default([])
  profile_completeness      Int                 @default(0)
  created_at                DateTime            @default(now())
  updated_at                DateTime            @updatedAt

  user                      User                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model NotificationPreferences {
  id                         String   @id @default(uuid())
  user_id                    String   @unique
  email_enabled              Boolean  @default(true)
  email_frequency            String   @default("IMMEDIATE") // IMMEDIATE, DAILY, WEEKLY
  push_enabled               Boolean  @default(false)
  alert_new_eligible_exam    Boolean  @default(true)
  alert_deadline_approaching Boolean  @default(true)
  alert_deadline_days_before Int      @default(3)
  alert_admit_card_released  Boolean  @default(true)
  alert_result_declared      Boolean  @default(true)
  alert_answer_key_released  Boolean  @default(false)
  quiet_hours_enabled        Boolean  @default(false)
  quiet_hours_start          String   @default("22:00")
  quiet_hours_end            String   @default("08:00")
  notification_language      String   @default("en")
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  user                       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Exam {
  id                         String             @id @default(uuid())
  slug                       String             @unique
  name                       String
  short_name                 String?
  category                   ExamCategory
  conducting_body            String
  level                      ExamLevel
  state_code                 String?
  total_vacancies            Int?
  vacancies_by_category      Json?
  notification_date          DateTime?          @db.Date
  application_start          DateTime?          @db.Date
  application_end            DateTime           @db.Date
  exam_date                  DateTime?          @db.Date
  admit_card_date            DateTime?          @db.Date
  result_date                DateTime?          @db.Date
  min_age                    Int?
  max_age_general            Int?
  max_age_obc                Int?
  max_age_sc_st              Int?
  max_age_ews                Int?
  max_age_pwd_general        Int?
  max_age_pwd_obc            Int?
  max_age_pwd_sc_st          Int?
  max_age_ex_serviceman      Int?
  age_cutoff_date            DateTime?          @db.Date
  required_qualification     QualificationLevel
  required_streams           String[]           @default([])
  min_marks_percentage       Float?
  allows_final_year          Boolean            @default(false)
  nationality_requirement    Nationality        @default(INDIAN)
  gender_restriction         Gender?
  physical_requirements      Json?
  marital_status_requirement MaritalStatus?
  official_notification_url  String
  notification_verified      Boolean            @default(false)
  data_source                DataSource         @default(MANUAL)
  is_active                  Boolean            @default(false)
  is_cancelled               Boolean            @default(false)
  cancellation_reason        String?
  application_fee_general    Float?
  application_fee_sc_st      Float?
  application_fee_pwd        Float?
  application_fee_women      Float?
  fee_payment_mode           String[]           @default([])
  description                String?
  syllabus_summary           String?
  selection_process          String[]           @default([])
  created_at                 DateTime           @default(now())
  updated_at                 DateTime           @updatedAt
  created_by                 String?
  last_verified_at           DateTime?

  tracked_by                 TrackedExam[]

  @@map("exams")
}

model TrackedExam {
  id                 String        @id @default(uuid())
  user_id            String
  exam_id            String
  status             TrackedStatus @default(TRACKING)
  application_number String?
  roll_number        String?
  marks_obtained     Float?
  rank_obtained      Int?
  tracked_at         DateTime      @default(now())
  applied_at         DateTime?
  updated_at         DateTime      @updatedAt

  user               User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  exam               Exam          @relation(fields: [exam_id], references: [id], onDelete: Cascade)

  @@unique([user_id, exam_id])
  @@map("tracked_exams")
}

// ─── Scraper Infrastructure ─────────────────────────────────────────────────

model ScraperLog {
  id              String   @id @default(uuid())
  site_id         String
  status          String
  content_hash    String?
  http_status     Int?
  error_message   String?
  duration_ms     Int
  new_pdfs_found  Int      @default(0)
  scraped_at      DateTime @default(now())

  @@index([site_id, scraped_at])
  @@map("scraper_log")
}

model PdfHash {
  id           String   @id @default(uuid())
  hash         String   @unique
  source_url   String
  site_id      String
  storage_path String?
  created_at   DateTime @default(now())

  @@map("pdf_hashes")
}

model PdfIngestionLog {
  id              String   @id @default(uuid())
  pdf_hash        String
  ai_status       String   @default("PENDING") // PENDING, SUCCESS, FAILED
  ai_error        String?
  exam_id         String?
  processing_time Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("pdf_ingestion_log")
}
